{
  "scripts": {
    "sync:public": "node scripts/sync-public.mjs",
    "dev:cf": "npm run sync:public && wrangler dev --port 8787",
    "deploy:cf": "npm run sync:public && wrangler deploy",
    "d1:migrate:local": "wrangler d1 migrations apply xiaohongshu-cover-db --local",
    "d1:migrate:remote": "wrangler d1 migrations apply xiaohongshu-cover-db --remote",
    "supabase:functions:deploy": "supabase functions deploy authorize-download && supabase functions deploy admin-manage && supabase functions deploy create-payment-order && supabase functions deploy payment-webhook",
    "radar:fetch": "node scripts/fetch-reddit-rss.mjs",
    "radar:analyze": "node scripts/analyze-reddit-posts.mjs",
    "radar:run": "node scripts/fetch-reddit-rss.mjs && node scripts/analyze-reddit-posts.mjs"
  },
  "devDependencies": {
    "wrangler": "4.86.0"
  }
}
